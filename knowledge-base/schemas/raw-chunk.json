{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "nutriguide/knowledge-base/schemas/raw-chunk.json",
  "title": "Raw Knowledge Chunk",
  "description": "从原始材料中提取的一条知识片段，未经结构化处理",
  "type": "object",
  "required": [
    "id",
    "source",
    "raw_text",
    "category",
    "claim_type"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^chunk_\\d{3,}$",
      "description": "唯一标识，如 chunk_001"
    },
    "source": {
      "type": "object",
      "required": [
        "type",
        "title"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "book",
            "paper",
            "website",
            "guideline",
            "database"
          ]
        },
        "title": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "year": {
          "type": "integer"
        },
        "page": {
          "type": "string"
        },
        "chapter": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "access_date": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "raw_text": {
      "type": "string",
      "minLength": 10,
      "description": "原始文本，保持原文不动"
    },
    "category": {
      "type": "string",
      "enum": [
        "macronutrient",
        "micronutrient",
        "food",
        "diet_pattern",
        "diet_principle",
        "population",
        "supplement",
        "assessment",
        "disease_nutrition"
      ]
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "fact",
        "guideline",
        "opinion",
        "data_point",
        "meta_analysis"
      ],
      "description": "fact=客观事实; guideline=官方指南建议; opinion=专家观点; data_point=数值数据; meta_analysis=荟萃分析结论"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "自由标签，参考 taxonomy.json 中的 tags"
    },
    "numeric_data": {
      "type": "object",
      "description": "如果原始文本含数值，在此规范化存储",
      "properties": {
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        },
        "context": {
          "type": "string"
        }
      }
    },
    "related_chunks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "相关 chunk ID 列表"
    },
    "notes": {
      "type": "string",
      "description": "提炼师备注（如翻译、歧义、需要下游注意的事项）"
    },
    "extracted_date": {
      "type": "string",
      "format": "date"
    }
  }
}