{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "nutriguide/knowledge-base/schemas/food-entry.json",
  "title": "Structured Food Entry",
  "description": "一条结构化的食物数据条目，含每100g营养素含量",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "nutrients_per_100g"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^food_\\d{3,}$"
    },
    "name": {
      "type": "string",
      "description": "中文食物名称"
    },
    "name_en": {
      "type": "string",
      "description": "英文名（如有）"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "别名/俗称"
    },
    "category": {
      "type": "string",
      "enum": [
        "grains",
        "vegetables",
        "fruits",
        "meat_poultry",
        "seafood",
        "eggs",
        "dairy",
        "soy_products",
        "nuts_seeds",
        "oils_fats",
        "beverages",
        "condiments"
      ]
    },
    "nutrients_per_100g": {
      "type": "object",
      "required": [
        "energy_kcal",
        "protein_g",
        "fat_g",
        "carbs_g"
      ],
      "properties": {
        "energy_kcal": {
          "type": "number",
          "minimum": 0
        },
        "protein_g": {
          "type": "number",
          "minimum": 0
        },
        "fat_g": {
          "type": "number",
          "minimum": 0
        },
        "carbs_g": {
          "type": "number",
          "minimum": 0
        },
        "fiber_g": {
          "type": "number",
          "minimum": 0
        },
        "sugar_g": {
          "type": "number",
          "minimum": 0
        },
        "vitaminA_ugRAE": {
          "type": "number",
          "minimum": 0
        },
        "vitaminD_ug": {
          "type": "number",
          "minimum": 0
        },
        "vitaminE_mg": {
          "type": "number",
          "minimum": 0
        },
        "vitaminK_ug": {
          "type": "number",
          "minimum": 0
        },
        "vitaminC_mg": {
          "type": "number",
          "minimum": 0
        },
        "thiamin_mg": {
          "type": "number",
          "minimum": 0
        },
        "riboflavin_mg": {
          "type": "number",
          "minimum": 0
        },
        "niacin_mg": {
          "type": "number",
          "minimum": 0
        },
        "vitaminB6_mg": {
          "type": "number",
          "minimum": 0
        },
        "folate_ug": {
          "type": "number",
          "minimum": 0
        },
        "vitaminB12_ug": {
          "type": "number",
          "minimum": 0
        },
        "calcium_mg": {
          "type": "number",
          "minimum": 0
        },
        "iron_mg": {
          "type": "number",
          "minimum": 0
        },
        "zinc_mg": {
          "type": "number",
          "minimum": 0
        },
        "magnesium_mg": {
          "type": "number",
          "minimum": 0
        },
        "selenium_ug": {
          "type": "number",
          "minimum": 0
        },
        "iodine_ug": {
          "type": "number",
          "minimum": 0
        },
        "potassium_mg": {
          "type": "number",
          "minimum": 0
        },
        "sodium_mg": {
          "type": "number",
          "minimum": 0
        },
        "omega3_g": {
          "type": "number",
          "minimum": 0
        },
        "cholesterol_mg": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "standard_portion": {
      "type": "object",
      "description": "标准份量定义",
      "properties": {
        "amount": {
          "type": "string",
          "description": "如 '200g' 或 '1个(约200g)'"
        },
        "unit": {
          "type": "string"
        }
      }
    },
    "glycemic_index": {
      "type": "number",
      "minimum": 0,
      "maximum": 120,
      "description": "GI值（如有）"
    },
    "glycemic_load": {
      "type": "number",
      "minimum": 0,
      "description": "标准份量的GL值"
    },
    "bioavailability_notes": {
      "type": "string",
      "description": "营养素生物利用率说明"
    },
    "antinutrients": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "含有的抗营养因子（如草酸、植酸）"
    },
    "cooking_impact": {
      "type": "string",
      "description": "烹饪方式对营养素的影响"
    },
    "food_synergy": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "paired_with": {
            "type": "string"
          },
          "effect": {
            "type": "string"
          }
        }
      },
      "description": "食物搭配协同效应"
    },
    "seasonal_info": {
      "type": "string",
      "description": "季节性信息"
    },
    "common_in_diets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "常见于哪些膳食模式"
    },
    "evidence_level": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "数据置信度评分"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "关联的 raw_chunk ID 列表"
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    }
  }
}