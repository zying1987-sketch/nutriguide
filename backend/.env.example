# NutriGuide 后端环境配置

# 服务器端口
PORT=3030

# SQLite 数据库路径（默认 backend/nutriguide.db，Docker 中建议 /app/data/nutriguide.db）
DB_PATH=

# JWT 密钥（生产环境请更换为随机字符串）
JWT_SECRET=nutriguide-dev-secret-change-in-production

# === SMTP 邮件配置（用于发送验证码） ===
# 126邮箱示例：
# SMTP_HOST=smtp.126.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@126.com
# SMTP_PASS=your-auth-code
# SMTP_FROM=your-email@126.com
#
# QQ邮箱示例：
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@qq.com
# SMTP_PASS=your-auth-code
# SMTP_FROM=your-email@qq.com
#
# 未配置 SMTP 时，验证码将打印到服务器控制台（开发模式）

# === LLM API Keys（用于增强报告生成和 AI 即时咨询） ===
# 通义千问（阿里云百炼，国内直连，推荐首选）：
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
#
# DeepSeek：https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=your-deepseek-api-key
#
# Gemini：https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key

# 前端地址（生产环境配置）
FRONTEND_URL=http://localhost:3030
